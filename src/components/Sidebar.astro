---
// src/components/Sidebar.astro
import { supabase } from '../lib/supabase.js';

const { data: categories, error } = await supabase
  .from('categories')
  .select('*')
  .order('name');

if (error) {
  console.error('Erro ao buscar categorias no Sidebar:', error);
}
---

<aside class="sidebar">
  <div class="sidebar-widget">
    <h3 class="widget-title">Categorias</h3>
    <ul class="category-list">
      {categories && categories.length > 0 ? (
        categories.map(category => (
          <li>
            <a href={`/category/${category.slug}`}>
              {category.name}
            </a>
          </li>
        ))
      ) : (
        <p class="no-categories">Nenhuma categoria encontrada.</p>
      )}
    </ul>
  </div>

  <div class="sidebar-widget">
    <a href="/contato" class="sidebar-banner">
      <img src="/images/banner-lateral.png" alt="Banner Informativo" onerror="this.style.display='none'; this.parentElement.classList.add('fallback-banner');" />
      <div class="banner-overlay">
        <span>Participe das nossas atividades</span>
      </div>
    </a>
  </div>
</aside>

<style>
  .sidebar {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .sidebar-widget {
    background: #fff;
    padding: 30px;
    border-radius: 16px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.05);
  }

  .widget-title {
    font-size: 1.5rem;
    color: var(--text-dark, #333);
    margin-bottom: 25px;
    padding-bottom: 15px;
    border-bottom: 2px solid var(--primary-light, #e0f2f1);
    position: relative;
  }

  .widget-title::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 50px;
    height: 2px;
    background: var(--primary);
  }

  .category-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .category-list li {
    margin-bottom: 12px;
  }

  .category-list li a {
    color: #555;
    text-decoration: none;
    font-weight: 500;
    display: block;
    padding: 8px 12px;
    border-radius: 8px;
    transition: all 0.2s ease;
    background: #f8f9fa;
  }

  .category-list li a:hover {
    background: var(--primary);
    color: white;
    transform: translateX(5px);
  }

  .sidebar-banner {
    display: block;
    position: relative;
    width: 100%;
    min-height: 350px;
    border-radius: 12px;
    overflow: hidden;
    background: linear-gradient(135deg, #00796b, #4db6ac);
    text-decoration: none;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 10px 20px rgba(0,0,0,0.1);
  }

  .sidebar-banner:hover {
    transform: translateY(-5px);
  }

  .sidebar-banner img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .sidebar-banner.fallback-banner {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 30px;
    text-align: center;
  }

  .banner-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 40px 20px 20px;
    background: linear-gradient(to top, rgba(0,0,0,0.8), transparent);
    color: white;
    font-weight: 600;
    font-size: 1.1rem;
    line-height: 1.4;
    transition: padding-bottom 0.3s ease;
  }

  .sidebar-banner:hover .banner-overlay {
    padding-bottom: 30px;
  }
</style>
