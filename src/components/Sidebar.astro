---
// src/components/Sidebar.astro
import { supabase } from '../lib/supabase.js';

const { data: categories, error } = await supabase
  .from('categories')
  .select('*')
  .order('name');

if (error) {
  console.error('Erro ao buscar categorias no Sidebar:', error);
}
---

<aside class="sidebar">
  <div class="sidebar-widget">
    <h3 class="widget-title">Categorias</h3>
    <ul class="category-list">
      {categories && categories.length > 0 ? (
        categories.map(category => (
          <li>
            <a href={`/category/${category.slug}`}>
              {category.name}
            </a>
          </li>
        ))
      ) : (
        <p class="no-categories">Nenhuma categoria encontrada.</p>
      )}
    </ul>
  </div>

  <div class="sidebar-widget banner-widget">
    <div class="banner-placeholder">
      <span>Espaço para Banner</span>
    </div>
  </div>
</aside>

<style>
  .sidebar {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .sidebar-widget {
    background: #fff;
    padding: 30px;
    border-radius: 16px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.05);
  }

  .widget-title {
    font-size: 1.5rem;
    color: var(--text-dark, #333);
    margin-bottom: 25px;
    padding-bottom: 15px;
    border-bottom: 2px solid var(--primary-light, #e0f2f1);
    position: relative;
  }

  .widget-title::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 50px;
    height: 2px;
    background: var(--primary);
  }

  .category-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .category-list li {
    margin-bottom: 12px;
  }

  .category-list li a {
    color: #555;
    text-decoration: none;
    font-weight: 500;
    display: block;
    padding: 8px 12px;
    border-radius: 8px;
    transition: all 0.2s ease;
    background: #f8f9fa;
  }

  .category-list li a:hover {
    background: var(--primary);
    color: white;
    transform: translateX(5px);
  }

  .banner-placeholder {
    width: 100%;
    height: 300px;
    background: #eee;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #999;
    font-weight: 600;
    border: 2px dashed #ccc;
  }
</style>
