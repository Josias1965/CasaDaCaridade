---
// src/components/VisitorCounter.astro
import { supabase } from '../lib/supabase';

// No servidor, apenas buscamos o valor atual para exibição rápida
let count = 0;
try {
  const { data } = await supabase
    .from('site_visits')
    .select('count')
    .eq('page_slug', 'global')
    .single();
  if (data) count = data.count;
} catch (e) {
  console.error("Erro ao buscar contador:", e);
}
---

<div class="visitor-counter" id="counter-container">
  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-users"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
  <span class="text">Visitantes:</span>
  <span class="count" id="visitor-count">{count > 0 ? count.toLocaleString() : '---'}</span>
</div>

<script>
  import { supabase } from '../lib/supabase';

  async function handleVisit() {
    const VISIT_KEY = 'casa_caridade_visited_v2'; // v2 para resetar e testar
    const hasVisited = localStorage.getItem(VISIT_KEY);
    const countDisplay = document.getElementById('visitor-count');

    if (!hasVisited) {
      // Primeira vez nesta sessão/navegador: incrementa
      const { data, error } = await supabase.rpc('increment_site_visit', { slug: 'global' });
      
      if (!error && data !== null) {
        if (countDisplay) countDisplay.textContent = data.toLocaleString();
        // Marca como visitado (pode ser um timestamp para expirar em 24h se quiser)
        localStorage.setItem(VISIT_KEY, Date.now().toString());
      }
    }
  }

  // Executa ao carregar
  handleVisit();
</script>

<style>
  .visitor-counter {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 8px 18px;
    background: rgba(255, 255, 255, 0.03);
    border-radius: 12px;
    font-size: 0.85rem;
    color: #a0a0a0;
    margin-top: 15px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    transition: all 0.3s ease;
  }
  .visitor-counter:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: var(--primary);
  }
  .count {
    color: var(--primary, #009688);
    font-weight: 700;
    font-family: 'Inter', sans-serif;
  }
  svg {
    color: var(--primary);
    opacity: 0.8;
  }
</style>
