---
// src/components/BlogCard.astro
interface Props {
  title: string;
  excerpt: string;
  slug: string;
  image?: string;
  category?: string;
  author?: string;
  date?: string;
}

const { title, excerpt, slug, image, category, author, date } = Astro.props;
const formattedDate = date ? new Date(date).toLocaleDateString('pt-BR') : '';
---
<article class="blog-card">
  <div class="card-content">
    <div class="card-meta">
      {category && <span class="category">{category}</span>}
      {formattedDate && <span class="date">{formattedDate}</span>}
    </div>
    <h2 class="card-title">
      <a href={`/blog/${slug}`}>{title}</a>
    </h2>
    
    {image && (
      <div class="card-image">
        <img src={image} alt={title} />
      </div>
    )}

    <p class="card-excerpt">{excerpt}</p>
    <div class="card-footer">
      {author && <span class="author">Por {author}</span>}
      <a href={`/blog/${slug}`} class="read-more">Leia mais &rarr;</a>
    </div>
  </div>
</article>

<style>
  .blog-card {
    background: white;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    transition: transform 0.3s;
    display: flex;
    flex-direction: column;
  }
  .blog-card:hover {
    transform: translateY(-5px);
  }
  .card-image img {
    width: 100%;
    height: 200px;
    object-fit: cover;
  }
  .card-content {
    padding: 20px;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }
  .card-meta {
    font-size: 0.8rem;
    margin-bottom: 10px;
    color: #666;
    display: flex;
    gap: 15px;
  }
  .category {
    color: var(--primary);
    font-weight: 600;
    text-transform: uppercase;
  }
  .card-title {
    font-size: 1.25rem;
    margin-bottom: 15px;
    line-height: 1.3;
  }
  .card-title a:hover {
    color: var(--secondary);
  }
  .card-excerpt {
    color: #555;
    font-size: 0.95rem;
    margin-bottom: 20px;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
    line-height: 1.5;
  }
  .card-footer {
    border-top: 1px solid #eee;
    padding-top: 15px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.85rem;
  }
  .author {
    font-style: italic;
  }
  .read-more {
    color: var(--secondary);
    font-weight: 600;
  }
</style>
