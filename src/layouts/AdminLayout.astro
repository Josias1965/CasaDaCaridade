---
// src/layouts/AdminLayout.astro
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="pt-br">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<title>{title} | Admin - Casa da Caridade</title>
	</head>
	<body class="admin-body">
		<div class="admin-layout">
			<aside class="admin-sidebar">
				<div class="sidebar-brand">
					<h2>Casa da Caridade</h2>
				</div>
				<nav class="sidebar-nav">
					<a href="/admin/dashboard" class="nav-item">Dashboard</a>
					<a href="/admin/posts" class="nav-item">Posts</a>
					<a href="/admin/posts/novo" class="nav-item">Novo Post</a>
					<a href="/admin/categorias" class="nav-item">Categorias</a>
					<a href="/admin/usuarios" class="nav-item">Usuários</a>
					<div class="nav-divider"></div>
					<a href="/home" class="nav-item secondary">Ver Site</a>
				</nav>
			</aside>
			<main class="admin-main">
				<div class="admin-content">
					<slot />
				</div>
			</main>
		</div>
	</body>
</html>

<style>
	.admin-body {
		background-color: #f4f7f6;
		margin: 0;
		font-family: 'Inter', system-ui, sans-serif;
	}
	.admin-layout {
		display: flex;
		min-height: 100vh;
	}
	.admin-sidebar {
		width: 260px;
		background: #2d3436;
		color: white;
		display: flex;
		flex-direction: column;
		position: fixed;
		height: 100vh;
	}
	.sidebar-brand {
		padding: 30px 20px;
		border-bottom: 1px solid rgba(255,255,255,0.1);
	}
	.sidebar-brand h2 {
		font-size: 1.2rem;
		margin: 0;
		color: var(--primary);
	}
	.sidebar-nav {
		padding: 20px 0;
		display: flex;
		flex-direction: column;
	}
	.nav-item {
		padding: 12px 25px;
		color: rgba(255,255,255,0.7);
		text-decoration: none;
		transition: all 0.2s;
		font-size: 0.95rem;
	}
	.nav-item:hover {
		background: rgba(255,255,255,0.05);
		color: white;
	}
	.nav-divider {
		height: 1px;
		background: rgba(255,255,255,0.1);
		margin: 15px 0;
	}
	.admin-main {
		flex: 1;
		margin-left: 260px;
		padding: 40px;
	}
	.admin-content {
		max-width: 1200px;
		margin: 0 auto;
	}
</style>
