---
// src/layouts/AdminLayout.astro
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="pt-br">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Admin - Casa da Caridade</title>
  </head>
  <body class="admin-body">

    <!-- ── Mobile top bar ── -->
    <header class="mobile-topbar" id="mobileTopbar">
      <button class="hamburger" id="hamburgerBtn" aria-label="Abrir menu" aria-expanded="false">
        <span></span>
        <span></span>
        <span></span>
      </button>
      <span class="mobile-brand">Casa da Caridade</span>
    </header>

    <!-- ── Overlay ── -->
    <div class="sidebar-overlay" id="sidebarOverlay" aria-hidden="true"></div>

    <div class="admin-layout">
      <!-- ── Sidebar ── -->
      <aside class="admin-sidebar" id="adminSidebar">
        <div class="sidebar-brand">
          <h2>Casa da Caridade</h2>
        </div>
        <nav class="sidebar-nav">
          <a href="/admin/dashboard" class="nav-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
            Dashboard
          </a>
          <a href="/admin/posts" class="nav-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            Posts
          </a>
          <a href="/admin/posts/novo" class="nav-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Novo Post
          </a>
          <a href="/admin/categorias" class="nav-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
            Categorias
          </a>
          <a href="/admin/usuarios" class="nav-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            Usuários
          </a>
          <div class="nav-divider"></div>
          <a href="/home" class="nav-item secondary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            Ver Site
          </a>
        </nav>
      </aside>

      <!-- ── Main ── -->
      <main class="admin-main">
        <div class="admin-content">
          <slot />
        </div>
      </main>
    </div>
  </body>
</html>

<style>
  /* ── Reset / Base ── */
  *, *::before, *::after { box-sizing: border-box; }

  .admin-body {
    background-color: #f4f7f6;
    margin: 0;
    font-family: 'Inter', system-ui, sans-serif;
    overflow-x: hidden;
  }

  /* ── Layout ── */
  .admin-layout {
    display: flex;
    min-height: 100vh;
  }

  /* ── Sidebar ── */
  .admin-sidebar {
    width: 240px;
    flex-shrink: 0;
    background: #2d3436;
    color: white;
    display: flex;
    flex-direction: column;
    position: fixed;
    top: 0;
    left: 0;
    height: 100vh;
    z-index: 900;
    overflow-y: auto;
    transition: transform 0.28s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .sidebar-brand {
    padding: 28px 20px 22px;
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }
  .sidebar-brand h2 {
    font-size: 1.1rem;
    margin: 0;
    color: var(--primary, #00b894);
    line-height: 1.2;
  }

  .sidebar-nav {
    padding: 16px 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .nav-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 11px 20px;
    color: rgba(255,255,255,0.7);
    text-decoration: none;
    transition: background 0.18s, color 0.18s;
    font-size: 0.92rem;
    border-radius: 0;
  }
  .nav-item:hover {
    background: rgba(255,255,255,0.07);
    color: white;
  }
  .nav-item svg { flex-shrink: 0; opacity: 0.7; }
  .nav-item:hover svg { opacity: 1; }

  .nav-divider {
    height: 1px;
    background: rgba(255,255,255,0.1);
    margin: 10px 0;
  }

  /* ── Overlay ── */
  .sidebar-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.55);
    z-index: 800;
    backdrop-filter: blur(1px);
    opacity: 0;
    transition: opacity 0.28s;
  }
  .sidebar-overlay.active {
    display: block;
    opacity: 1;
  }

  /* ── Mobile top bar (hidden on desktop) ── */
  .mobile-topbar {
    display: none;
    align-items: center;
    gap: 14px;
    background: #2d3436;
    padding: 13px 16px;
    position: sticky;
    top: 0;
    z-index: 700;
    box-shadow: 0 2px 8px rgba(0,0,0,0.25);
  }
  .mobile-brand {
    color: var(--primary, #00b894);
    font-weight: 700;
    font-size: 1rem;
  }

  /* ── Hamburger ── */
  .hamburger {
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    display: flex;
    flex-direction: column;
    gap: 5px;
    flex-shrink: 0;
  }
  .hamburger span {
    display: block;
    width: 22px;
    height: 2px;
    background: white;
    border-radius: 2px;
    transition: transform 0.25s, opacity 0.25s;
    transform-origin: center;
  }
  .hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .hamburger.open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* ── Main content ── */
  .admin-main {
    flex: 1;
    margin-left: 240px;
    min-width: 0;
  }
  .admin-content {
    padding: 36px 40px;
    max-width: 1200px;
    margin: 0 auto;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .admin-content { padding: 28px 24px; }
  }

  @media (max-width: 768px) {
    .mobile-topbar { display: flex; }

    .admin-sidebar {
      top: 0;
      transform: translateX(-100%);
    }
    .admin-sidebar.open {
      transform: translateX(0);
    }

    .admin-main {
      margin-left: 0;
    }
    .admin-content {
      padding: 20px 16px 40px;
    }
  }
</style>

<script>
  const sidebar  = document.getElementById('adminSidebar');
  const overlay  = document.getElementById('sidebarOverlay');
  const btn      = document.getElementById('hamburgerBtn');

  function openMenu() {
    sidebar?.classList.add('open');
    overlay?.classList.add('active');
    btn?.classList.add('open');
    btn?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    sidebar?.classList.remove('open');
    overlay?.classList.remove('active');
    btn?.classList.remove('open');
    btn?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  btn?.addEventListener('click', () => {
    sidebar?.classList.contains('open') ? closeMenu() : openMenu();
  });

  overlay?.addEventListener('click', closeMenu);

  // Fecha ao navegar (mobile)
  sidebar?.querySelectorAll('.nav-item').forEach(link => {
    link.addEventListener('click', closeMenu);
  });

  // Fecha se janela for redimensionada para desktop
  window.addEventListener('resize', () => {
    if (window.innerWidth > 768) closeMenu();
  });
</script>
