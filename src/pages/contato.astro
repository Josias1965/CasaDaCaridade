---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Contato" description="Entre em contato com a Casa da Caridade. Estaremos felizes em ouvir você.">
  <Header />
  
  <main class="contact-page">
    <section class="contact-hero">
      <div class="overlay"></div>
      <img src="/images/contato-banner.png" alt="Entre em Contato" class="hero-img" />
      <div class="container container-hero">
        <h1>Fale Conosco</h1>
        <p class="subtitle">Estamos à disposição para sugestões e parcerias.</p>
      </div>
    </section>

    <section class="contact-content">
      <div class="container narrow-container">
        <div class="card contact-card animate-up">
          <div class="contact-info">
            <div class="info-item">
              <span class="icon">📧</span>
              <div>
                <h3>E-mail</h3>
                <p>contato@casadacaridade.com.br</p>
              </div>
            </div>
            
            <div class="info-item">
              <span class="icon">📱</span>
              <div>
                <h3>Redes Sociais</h3>
                <p>Acompanhe nossos conteúdos diários.</p>
                <div class="social-links">
                  <a href="#">Instagram</a>
                  <a href="#">Facebook</a>
                  <a href="#">YouTube</a>
                </div>
              </div>
            </div>
          </div>
          
          <div class="contact-form">
            <h3>Envie uma Mensagem</h3>
            <p>Se tiver alguma dúvida ou reflexão para compartilhar, escreva para nós!</p>
            <form>
              <input type="text" placeholder="Seu Nome" required />
              <input type="email" placeholder="Seu E-mail" required />
              <textarea rows="5" placeholder="Sua Mensagem" required></textarea>
              <button type="submit" class="btn-primary">Enviar Mensagem</button>
            </form>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  /* Same base styles as about.astro for consistency */
  .contact-page { min-height: 100vh; }
  .contact-hero {
    position: relative;
    height: 300px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: white;
    overflow: hidden;
  }
  .hero-img {
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    object-fit: cover; z-index: -1;
  }
  .overlay {
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    background: linear-gradient(to bottom, rgba(0,0,0,0.3), rgba(0,0,0,0.6));
    z-index: 0;
  }
  .container-hero { position: relative; z-index: 1; }
  .contact-hero h1 { font-size: 3rem; font-weight: 800; margin-bottom: 10px; }
  
  .contact-content { padding: 60px 0; background: #f8f9fa; }
  .narrow-container { max-width: 900px; margin: 0 auto; }
  .contact-card {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    background: white;
    padding: 0;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 10px 40px rgba(0,0,0,0.05);
  }
  
  .contact-info {
    background: var(--secondary);
    color: white;
    padding: 50px;
  }
  .contact-info h3 { color: white; margin-bottom: 5px; font-size: 1.1rem; }
  .contact-info p { opacity: 0.8; font-size: 0.95rem; }
  
  .info-item { display: flex; gap: 15px; margin-bottom: 35px; }
  .icon { font-size: 1.5rem; }
  
  .social-links { display: flex; gap: 15px; margin-top: 15px; }
  .social-links a { color: var(--primary); font-size: 0.9rem; font-weight: 600; }
  .social-links a:hover { text-decoration: underline; }
  
  .contact-form { padding: 50px; }
  .contact-form h3 { color: var(--secondary); margin-bottom: 10px; }
  .contact-form p { color: #666; margin-bottom: 30px; font-size: 0.95rem; }
  
  form input, form textarea {
    width: 100%;
    padding: 12px 15px;
    margin-bottom: 15px;
    border: 1px solid #ddd;
    border-radius: 8px;
    font-family: inherit;
  }
  .btn-primary {
    width: 100%;
    background: var(--primary);
    color: white;
    padding: 12px;
    border: none;
    border-radius: 8px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.3s;
  }
  .btn-primary:hover { background: #3d9be9; }

  .animate-up { animation: fadeInUp 0.8s ease-out; }
  @keyframes fadeInUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }

  @media (max-width: 768px) {
    .contact-card { grid-template-columns: 1fr; }
    .contact-info, .contact-form { padding: 30px; }
  }
</style>
