---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { requireAuth } from '../../../lib/permissions.js';

const { authorized } = await requireAuth(Astro.cookies);
if (!authorized) return Astro.redirect('/admin/login');
---

<AdminLayout title="Gestão de Usuários (v2.4)">
  <div class="users-page">
    <header class="page-header">
      <h1>Painel de Acessos <small style="font-size: 0.5em; opacity: 0.5;">(v2.4)</small></h1>
      <p>Gerencie quem pode publicar e editar no sistema.</p>
    </header>

    <!-- Modal de Edição -->
    <div id="edit-modal" class="modal-overlay" style="display: none;">
      <div class="modal-content admin-card">
        <h3>✏️ Detalhes da Conta</h3>
        <form id="edit-user-form">
          <input type="hidden" id="edit-id" />
          <div class="form-group">
            <label>E-mail do Usuário</label>
            <input type="text" id="edit-email" disabled />
          </div>
          <div class="form-group">
            <label for="edit-name">Nome Completo</label>
            <input type="text" id="edit-name" required />
          </div>
          <div class="form-group">
            <label for="edit-role-select">Nível de Permissão</label>
            <select id="edit-role-select" required>
              <option value="" disabled selected>Carregando permissões...</option>
            </select>
          </div>
          <div class="modal-actions">
            <button type="button" id="close-modal" class="btn-secondary">Cancelar</button>
            <button type="submit" class="btn-primary highlight">Gravar Alterações</button>
          </div>
        </form>
      </div>
    </div>

    <section class="registration-section">
      <div class="admin-card">
        <h3>Novo Integrante</h3>
        <form id="register-form" class="inline-form">
          <div class="form-grid">
            <div class="form-group">
              <label for="display_name">Nome</label>
              <input type="text" id="display_name" name="display_name" required placeholder="Ex: Josias" />
            </div>
            <div class="form-group">
              <label for="email">E-mail</label>
              <input type="email" id="email" name="email" required placeholder="exemplo@gmail.com" />
            </div>
            <div class="form-group">
              <label for="role">Permissão</label>
              <select id="role" name="role" required>
                <option value="admin" selected>Administrador</option>
                <option value="editor">Editor (Publica)</option>
                <option value="author">Autor (Rascunho)</option>
              </select>
            </div>
            <div class="form-group">
              <label for="password">Senha Temporária</label>
              <input type="password" id="password" name="password" required minlength="6" />
            </div>
            <div class="form-actions">
              <button type="submit" class="btn-primary highlight">Registrar</button>
            </div>
          </div>
          <div id="status-message" style="display: none; margin-top: 20px; padding: 15px; border-radius: 8px;"></div>
        </form>
      </div>
    </section>

    <section class="users-list-section">
      <div class="admin-card">
        <h3>Tabela de Usuários</h3>
        <div id="users-table-container">
          <p>Carregando dados estruturados...</p>
        </div>
      </div>
    </section>
  </div>

  <script>
    import { supabase } from '../../../lib/supabase.js';

    const form = document.getElementById('register-form');
    const statusMsg = document.getElementById('status-message');
    const tableContainer = document.getElementById('users-table-container');
    const editModal = document.getElementById('edit-modal');
    const editForm = document.getElementById('edit-user-form');
    const closeBtn = document.getElementById('close-modal');

    let allRoles = [];

    async function loadRoles() {
      // 1. Tentar buscar roles do banco
      const { data, error } = await supabase.from('roles').select('id, name');
      
      if (!error && data && data.length > 0) {
        allRoles = data.filter(r => r.id && r.name);
      } else if (!error && (!data || data.length === 0)) {
        // Tabela roles está vazia! Vamos tentar injetar o registro básico
        console.warn("Tabela roles vazia. Tentando autocompletar...");
        const defaultRoles = [
          { name: 'admin', permissions: { posts: ["create", "read", "update", "delete"], users: ["manage"] } },
          { name: 'editor', permissions: { posts: ["create", "read", "update"], users: [] } },
          { name: 'author', permissions: { posts: ["create", "read"], users: [] } }
        ];
        const { data: inserted } = await supabase.from('roles').insert(defaultRoles).select('id, name');
        if (inserted) allRoles = inserted;
      } else {
        console.error("Erro RLS ao buscar roles:", error);
      }
    }

    async function loadUsers() {
      // 1. Carregamos os perfis
      const { data: profiles, error: pError } = await supabase
        .from('user_profiles')
        .select('*, roles(id, name)')
        .order('created_at', { ascending: false });

      if (pError) {
        tableContainer.innerHTML = `<p style="color: red">Erro: ${pError.message}</p>`;
        return;
      }

      // 2. Carrega roles se ainda não carregados
      if (allRoles.length === 0) await loadRoles();

      // 3. Fallback inteligente: Extrair das relacoes, caso a busca nativa de roles fudeu
      profiles.forEach(p => {
        // p.roles pode vir como array em algumas estruturas do Supabase
        const roleObj = Array.isArray(p.roles) ? p.roles[0] : p.roles;
        if (roleObj && roleObj.id && roleObj.name) {
          if (!allRoles.find(r => r.id === roleObj.id)) {
            allRoles.push({ id: roleObj.id, name: roleObj.name });
          }
        }
      });

      tableContainer.innerHTML = `
        <table class="admin-table">
          <thead>
            <tr>
              <th style="width: 25%">Nome</th>
              <th style="width: 35%">E-mail</th>
              <th style="width: 20%">Permissão</th>
              <th style="width: 20%; text-align: right">Ações</th>
            </tr>
          </thead>
          <tbody>
            ${profiles.map(u => {
              const roleObj = Array.isArray(u.roles) ? u.roles[0] : u.roles;
              const roleNameRaw = roleObj?.name || 'admin';
              const roleName = roleNameRaw.toLowerCase();
              const displayRole = roleName === 'admin' ? 'Administrador' : roleName === 'editor' ? 'Editor' : 'Autor';
              const displayEmail = u.email || '⚠️ Sem E-mail';
              return `
              <tr>
                <td><strong>${u.display_name || 'Usuário'}</strong></td>
                <td class="email-text">${displayEmail}</td>
                <td><span class="badge ${roleName}">${displayRole}</span></td>
                <td style="text-align: right; display: flex; gap: 8px; justify-content: flex-end;">
                  <button type="button" class="btn-secondary action-edit" style="padding: 6px 10px; font-size: 0.8rem;" data-user='${JSON.stringify(u).replace(/'/g, "&apos;")}'>✏️ Editar</button>
                  <button type="button" class="btn-secondary action-remove" style="padding: 6px 10px; font-size: 0.8rem; color: #dc3545;" data-user='${JSON.stringify(u).replace(/'/g, "&apos;")}'>🗑️ Remover</button>
                </td>
              </tr>
            `}).join('')}
          </tbody>
        </table>
      `;

      // Delegação de eventos para os novos botões
      document.querySelectorAll('.action-remove').forEach(btn => {
        btn.addEventListener('click', async (e) => {
          const user = JSON.parse(e.currentTarget.dataset.user);
          const confirmed = confirm(`Remover permanentemente ${user.display_name || user.email || 'este usuário'}?`);
          if (confirmed) {
            const { data, error } = await supabase.from('user_profiles').delete().eq('id', user.id).select();
            if (error) {
              alert("Erro ao remover: " + error.message);
            } else if (!data || data.length === 0) {
              alert("Remoção FALHOU! O Supabase bloqueou a deleção (política RLS no banco restringe o DELETE).");
            } else {
              alert("Usuário removido com sucesso!");
              loadUsers();
            }
          }
        });
      });

      document.querySelectorAll('.action-edit').forEach(btn => {
        btn.addEventListener('click', (e) => {
          const user = JSON.parse(e.currentTarget.dataset.user);
          openModal(user);
        });
      });
    }

    async function openModal(user) {
      document.getElementById('edit-id').value = user.id;
      document.getElementById('edit-email').value = user.email || 'null';
      document.getElementById('edit-name').value = user.display_name || '';
      
      const roleSelect = document.getElementById('edit-role-select');
      const translations = { 'admin': 'Administrador', 'editor': 'Editor', 'author': 'Autor', 'Admin': 'Administrador', 'Editor': 'Editor', 'Author': 'Autor' };

      if (allRoles.length === 0) await loadRoles();

      if (allRoles.length > 0) {
        roleSelect.innerHTML = allRoles.map(r => {
           const translated = translations[r.name] || translations[r.name.toLowerCase()] || r.name;
           return `<option value="${r.id}" ${user.role_id === r.id ? 'selected' : ''}>${translated}</option>`;
        }).join('');
      } else {
        roleSelect.innerHTML = '<option disabled>⚠️ A tabela roles no banco está vazia ou bloqueada.</option>';
      }
      
      editModal.style.display = 'flex';
    }

    closeBtn.addEventListener('click', () => {
      editModal.style.display = 'none';
    });

    editForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const id = document.getElementById('edit-id').value;
      const display_name = document.getElementById('edit-name').value;
      const role_id = document.getElementById('edit-role-select').value;

      const { error } = await supabase
        .from('user_profiles')
        .update({ display_name, role_id })
        .eq('id', id);

      if (error) {
        alert("Erro ao salvar: " + error.message);
      } else {
        alert("Alterações salvas com sucesso!");
        editModal.style.display = 'none';
        loadUsers();
      }
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      statusMsg.style.display = 'block';
      statusMsg.style.backgroundColor = '#f8f9fa';
      statusMsg.textContent = 'Processando registro...';

      const formData = new FormData(form);
      const email = formData.get('email');
      const password = formData.get('password');
      const display_name = formData.get('display_name');
      const roleName = formData.get('role');

      try {
        const { data: authData, error: authError } = await supabase.auth.signUp({
          email,
          password,
        });

        if (authError) throw authError;

        if (authData.user) {
        if (authData.user) {
          if (allRoles.length === 0) await loadRoles();
          // Fallback case-insensitive se RLS bloquear a tabela (tentativa pelo nome)
          const role = allRoles.find(r => r.name.toLowerCase() === roleName.toLowerCase());
          const theRoleID = role?.id;
          
          const { error: profileError } = await supabase
            .from('user_profiles')
            .update({ 
              display_name, 
              role_id: theRoleID 
            })
            .eq('id', authData.user.id);

          if (profileError) {
            // Se o update falhar, tentamos insert (fallback para novos triggers)
            await supabase.from('user_profiles').upsert({
              id: authData.user.id,
              display_name,
              email,
              role_id: role?.id
            });
          }

          statusMsg.style.backgroundColor = '#d4edda';
          statusMsg.textContent = 'Usuário registrado com sucesso!';
          form.reset();
          setTimeout(loadUsers, 1500);
        }
      } catch (err) {
        statusMsg.style.backgroundColor = '#f8d7da';
        statusMsg.textContent = 'Erro: ' + err.message;
      }
    });

    loadUsers();
  </script>

  <style>
    .users-page { padding: 20px; max-width: 1200px; margin: 0 auto; }
    .page-header { margin-bottom: 30px; border-left: 5px solid #000; padding-left: 20px; }
    .page-header h1 { font-size: 1.8rem; margin: 0; }
    .page-header p { color: #666; margin: 5px 0 0; }

    .admin-card { background: #fff; border-radius: 12px; padding: 25px; box-shadow: 0 4px 20px rgba(0,0,0,0.08); margin-bottom: 30px; border: 1px solid #eee; }
    .admin-card h3 { margin-top: 0; margin-bottom: 20px; font-size: 1.1rem; color: #333; display: flex; align-items: center; gap: 10px; }

    .form-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 15px; align-items: flex-end; }
    .form-group { display: flex; flex-direction: column; gap: 6px; }
    .form-group label { font-weight: 600; font-size: 0.85rem; color: #555; }
    .form-group input, .form-group select { padding: 10px; border: 2px solid #f0f0f0; border-radius: 8px; font-size: 0.95rem; transition: all 0.2s; }
    .form-group input:focus, .form-group select:focus { outline: none; border-color: #000; background: #fff; }

    .btn-primary { background: #000; color: #fff; border: none; padding: 12px 20px; border-radius: 8px; font-weight: 600; cursor: pointer; transition: all 0.2s; }
    .btn-primary:hover { background: #333; transform: translateY(-1px); }
    .btn-secondary { background: #f0f0f0; color: #333; border: none; padding: 12px 20px; border-radius: 8px; font-weight: 600; cursor: pointer; }

    .admin-table { width: 100%; border-collapse: collapse; }
    .admin-table th { text-align: left; padding: 12px; border-bottom: 2px solid #eee; color: #999; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; }
    .admin-table td { padding: 15px 12px; border-bottom: 1px solid #f8f8f8; vertical-align: middle; }

    .email-text { color: #666; font-family: 'Monaco', 'Consolas', monospace; font-size: 0.85rem; }
    .badge { padding: 4px 10px; border-radius: 6px; font-size: 0.7rem; font-weight: 800; text-transform: uppercase; }
    .badge.admin { background: #fee2e2; color: #991b1b; }
    .badge.editor { background: #dcfce7; color: #166534; }
    .badge.author { background: #fef9c3; color: #854d0e; }

    .action-select-box { padding: 6px 10px; border: 1px solid #ddd; border-radius: 6px; font-size: 0.85rem; cursor: pointer; background: #fff; }

    .modal-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.7); display: flex; align-items: center; justify-content: center; z-index: 1000; backdrop-filter: blur(5px); }
    .modal-content { width: 90%; max-width: 450px; animation: modalIn 0.3s cubic-bezier(0.16, 1, 0.3, 1); }
    @keyframes modalIn { from { transform: scale(0.95); opacity: 0; } to { transform: scale(1); opacity: 1; } }
    .modal-actions { display: flex; justify-content: flex-end; gap: 10px; margin-top: 25px; }

    #status-message { transition: all 0.3s ease; }
  </style>
</AdminLayout>
