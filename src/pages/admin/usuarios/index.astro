---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { requireAuth } from '../../../lib/permissions.js';

const { authorized } = await requireAuth(Astro.cookies);
if (!authorized) return Astro.redirect('/admin/login');
---

<AdminLayout title="Gestão de Usuários">
  <div class="users-page">
    <header class="page-header">
      <h1>Gestão de Usuários</h1>
      <p>Cadastre e gerencie os administradores do sistema.</p>
    </header>

    <!-- Modal de Edição -->
    <div id="edit-modal" class="modal-overlay" style="display: none;">
      <div class="modal-content admin-card">
        <h3>Editar Usuário</h3>
        <form id="edit-user-form">
          <input type="hidden" id="edit-id" />
          <div class="form-group" style="margin-bottom: 15px;">
            <label>E-mail (Não pode ser alterado)</label>
            <input type="text" id="edit-email" disabled style="background: #f5f5f5; cursor: not-allowed;" />
          </div>
          <div class="form-group" style="margin-bottom: 15px;">
            <label for="edit-name">Nome do Usuário</label>
            <input type="text" id="edit-name" required />
          </div>
          <div class="form-group" style="margin-bottom: 20px;">
            <label for="edit-role">Permissão</label>
            <select id="edit-role-select" required></select>
          </div>
          <div class="modal-actions">
            <button type="button" id="close-modal" class="btn-secondary">Cancelar</button>
            <button type="submit" class="btn-primary">Salvar Alterações</button>
          </div>
        </form>
      </div>
    </div>

    <section class="registration-section">
      <div class="admin-card">
        <h3>Novo Administrador</h3>
        <form id="register-form" class="inline-form">
          <div class="form-grid">
            <div class="form-group">
              <label for="display_name">Nome</label>
              <input type="text" id="display_name" required placeholder="Ex: Josias" />
            </div>
            <div class="form-group">
              <label for="email">E-mail</label>
              <input type="email" id="email" required placeholder="email@exemplo.com" />
            </div>
            <div class="form-group">
              <label for="role">Permissão</label>
              <select id="role" required>
                <option value="Admin">Administrador</option>
                <option value="Editor">Editor (Publicar)</option>
                <option value="Author">Autor (Rascunho)</option>
              </select>
            </div>
            <div class="form-group">
              <label for="password">Senha Inicial</label>
              <input type="password" id="password" required minlength="6" />
            </div>
            <div class="form-actions">
              <button type="submit" class="btn-primary">Cadastrar</button>
            </div>
          </div>
          <div id="status-message" style="display: none; margin-top: 15px; padding: 10px; border-radius: 4px;"></div>
        </form>
      </div>
    </section>

    <section class="users-list-section">
      <div class="admin-card">
        <h3>Usuários Existentes</h3>
        <div id="users-table-container">
          <p>Carregando usuários...</p>
        </div>
      </div>
    </section>
  </div>

  <script>
    import { supabase } from '../../../lib/supabase.js';

    const form = document.getElementById('register-form');
    const statusMsg = document.getElementById('status-message');
    const tableContainer = document.getElementById('users-table-container');
    
    // Modal Elements
    const editModal = document.getElementById('edit-modal');
    const editForm = document.getElementById('edit-user-form');
    const closeBtn = document.getElementById('close-modal');

    let allRoles = [];

    async function loadUsers() {
      const { data: { user: currentUser } } = await supabase.auth.getUser();

      const { data: profiles, error: pError } = await supabase
        .from('user_profiles')
        .select('*, roles(name)')
        .order('created_at', { ascending: false });

      const { data: roles, error: rError } = await supabase.from('roles').select('*');
      allRoles = roles || [];

      if (pError || rError) {
        tableContainer.innerHTML = `<p style="color: red">Erro: ${pError?.message || rError?.message}</p>`;
        return;
      }

      tableContainer.innerHTML = `
        <table class="admin-table">
          <thead>
            <tr>
              <th style="width: 20%">Nome</th>
              <th style="width: 30%">E-mail</th>
              <th style="width: 15%">Criação</th>
              <th style="width: 20%">Permissão</th>
              <th style="width: 15%; text-align: right">Ações</th>
            </tr>
          </thead>
          <tbody>
            ${profiles.map(u => {
              const roleName = u.roles?.name || 'Admin';
              return `
              <tr>
                <td class="user-name"><strong>${u.display_name || u.email || 'Usuário'}</strong></td>
                <td class="user-email-cell">${u.email || '-'}</td>
                <td class="date-cell">${u.created_at ? new Date(u.created_at).toLocaleDateString('pt-BR') : '-'}</td>
                <td>
                  <span class="badge ${roleName.toLowerCase()}">${roleName}</span>
                </td>
                <td style="text-align: right">
                  <select class="action-select-box" data-user='${JSON.stringify(u)}'>
                    <option value="" disabled selected>Opções ▾</option>
                    <option value="edit">✏️ Editar Registro</option>
                    <option value="remove">🗑️ Remover Usuário</option>
                  </select>
                </td>
              </tr>
            `}).join('')}
          </tbody>
        </table>
      `;

      // Listener para Ações
      document.querySelectorAll('.action-select-box').forEach(select => {
        select.addEventListener('change', async (e) => {
          const action = e.target.value;
          const user = JSON.parse(e.target.dataset.user);

          if (action === 'remove') {
            if (confirm(`Remover permanentemente ${user.email}?`)) {
               await supabase.from('user_profiles').delete().eq('id', user.id);
               loadUsers();
            }
          } else if (action === 'edit') {
             openModal(user);
          }
          e.target.value = "";
        });
      });
    }

    function openModal(user) {
      document.getElementById('edit-id').value = user.id;
      document.getElementById('edit-email').value = user.email || '-';
      document.getElementById('edit-name').value = user.display_name || '';
      
      const roleSelect = document.getElementById('edit-role-select');
      roleSelect.innerHTML = allRoles.map(r => `
        <option value="${r.id}" ${user.role_id === r.id ? 'selected' : ''}>${r.name}</option>
      `).join('');
      
      editModal.style.display = 'flex';
    }

    closeBtn.onclick = () => editModal.style.display = 'none';

    editForm.onsubmit = async (e) => {
      e.preventDefault();
      const id = document.getElementById('edit-id').value;
      const display_name = document.getElementById('edit-name').value;
      const role_id = document.getElementById('edit-role-select').value;

      const { error } = await supabase.from('user_profiles').update({ display_name, role_id }).eq('id', id);
      if (error) alert(error.message);
      else {
        editModal.style.display = 'none';
        loadUsers();
      }
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = document.getElementById('email').value;
      const password = document.getElementById('password').value;
      const displayName = document.getElementById('display_name').value;
      const roleName = document.getElementById('role').value;

      statusMsg.style.display = 'block';
      statusMsg.style.background = '#f0f0f0';
      statusMsg.textContent = 'Criando conta...';

      const { data: roleData } = await supabase.from('roles').select('id').eq('name', roleName).single();

      const { data: authData, error: authError } = await supabase.auth.signUp({
        email,
        password,
        options: { data: { display_name: displayName } }
      });

      if (authError) {
        statusMsg.style.background = '#fff0f0';
        statusMsg.style.color = '#e03131';
        statusMsg.textContent = authError.message;
        return;
      }

      if (authData.user) {
        await supabase.from('user_profiles').insert([{
           id: authData.user.id,
           display_name: displayName,
           email: email,
           role_id: roleData.id
        }]);
      }

      statusMsg.style.background = '#f2fcf2';
      statusMsg.style.color = '#0ca678';
      statusMsg.textContent = 'Usuário cadastrado com sucesso!';
      form.reset();
      setTimeout(loadUsers, 1000);
    });

    loadUsers();
  </script>
</AdminLayout>

<style>
  .users-page { padding: 20px 0; }
  .page-header { margin-bottom: 30px; }
  .page-header h1 { font-size: 2rem; margin-bottom: 5px; }
  .page-header p { color: #666; }

  .registration-section { margin-bottom: 30px; }
  .admin-card { background: white; padding: 25px; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.05); }
  .admin-card h3 { margin-bottom: 20px; font-size: 1.1rem; border-bottom: 1px solid #f0f0f0; padding-bottom: 10px; }

  .form-grid { display: grid; grid-template-columns: 1.5fr 1.5fr 1fr 1fr auto; gap: 15px; align-items: flex-end; }
  .form-group label { display: block; margin-bottom: 8px; font-weight: 600; font-size: 0.85rem; }
  .form-group input, .form-group select { width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 6px; background: white; outline: none; }
  .btn-primary { background: var(--primary); color: white; border: none; padding: 12px 20px; border-radius: 6px; cursor: pointer; font-weight: 600; }
  .btn-secondary { background: #eee; color: #444; border: none; padding: 12px 20px; border-radius: 6px; cursor: pointer; font-weight: 600; }

  .admin-table { width: 100%; border-collapse: collapse; margin-top: 20px; }
  .admin-table th { text-align: left; background: #f8f9fa; padding: 15px; border-bottom: 2px solid #eee; color: #444; font-size: 0.85rem; font-weight: 700; }
  .admin-table td { padding: 15px; border-bottom: 1px solid #f3f3f3; vertical-align: middle; color: #333; font-size: 0.9rem; }
  
  .user-name { color: #2d3436; }
  .user-email-cell { color: #636e72; font-family: monospace; }
  .date-cell { white-space: nowrap; }

  .action-select-box { width: 100%; padding: 8px 12px; border: 1px solid #ddd; border-radius: 4px; font-size: 0.85rem; background: #fff; cursor: pointer; color: #444; }

  .badge { padding: 4px 8px; border-radius: 4px; font-size: 0.7rem; font-weight: 800; text-transform: uppercase; }
  .badge.admin { background: #e3fafc; color: #0c8599; }
  .badge.editor { background: #fff4e6; color: #d9480f; }
  .badge.author { background: #f3f0ff; color: #5f3dc4; }

  /* Modal Styles */
  .modal-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); display: flex; align-items: center; justify-content: center; z-index: 10000; }
  .modal-content { width: 450px; position: relative; animation: slideUp 0.3s ease-out; }
  .modal-actions { display: flex; gap: 10px; justify-content: flex-end; margin-top: 20px; }

  @keyframes slideUp {
    from { transform: translateY(20px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }

  @media (max-width: 1024px) {
    .form-grid { grid-template-columns: 1fr 1fr; }
    .form-actions { grid-column: span 2; }
  }
</style>
