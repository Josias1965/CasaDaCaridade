---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { requireAuth } from '../../../lib/permissions.js';

const { authorized } = await requireAuth(Astro.cookies);
if (!authorized) return Astro.redirect('/admin/login');
---

<AdminLayout title="Gestão de Usuários">
  <div class="users-page">
    <header class="page-header">
      <h1>Gestão de Usuários</h1>
      <p>Cadastre e gerencie os administradores do sistema.</p>
    </header>

    <section class="registration-section">
      <div class="admin-card">
        <h3>Novo Administrador</h3>
        <form id="register-form" class="inline-form">
          <div class="form-grid">
            <div class="form-group">
              <label for="display_name">Nome</label>
              <input type="text" id="display_name" required placeholder="Ex: João Silva" />
            </div>
            <div class="form-group">
              <label for="email">E-mail</label>
              <input type="email" id="email" required placeholder="email@exemplo.com" />
            </div>
            <div class="form-group">
              <label for="password">Senha Inicial</label>
              <input type="password" id="password" required minlength="6" />
            </div>
            <div class="form-actions">
              <button type="submit" class="btn-primary">Cadastrar</button>
            </div>
          </div>
          <div id="status-message" style="display: none; margin-top: 15px; padding: 10px; border-radius: 4px;"></div>
        </form>
      </div>
    </section>

    <section class="users-list-section">
      <div class="admin-card">
        <h3>Usuários Existentes</h3>
        <div id="users-table-container">
          <p>Carregando usuários...</p>
        </div>
      </div>
    </section>
  </div>

  <script>
    import { supabase } from '../../../lib/supabase.js';

    const form = document.getElementById('register-form');
    const statusMsg = document.getElementById('status-message');
    const tableContainer = document.getElementById('users-table-container');

    async function loadUsers() {
      const { data: profiles, error } = await supabase
        .from('user_profiles')
        .select('*')
        .order('created_at', { ascending: false });

      if (error) {
        tableContainer.innerHTML = `<p style="color: red">Erro ao carregar: ${error.message}</p>`;
        return;
      }

      tableContainer.innerHTML = `
        <table class="admin-table">
          <thead>
            <tr>
              <th>Nome</th>
              <th>Criação</th>
              <th>Permissão</th>
              <th>Ações</th>
            </tr>
          </thead>
          <tbody>
            ${profiles.map(u => `
              <tr>
                <td>
                  <div class="user-info">
                    <strong>${u.display_name}</strong>
                    <span class="user-email">${u.email || ''}</span>
                  </div>
                </td>
                <td>${new Date(u.created_at).toLocaleDateString()}</td>
                <td><span class="role-badge admin">Admin</span></td>
                <td>
                  <div class="dropdown">
                    <button class="btn-dots">⋮</button>
                    <div class="dropdown-content">
                      <a href="#" onclick="alert('Função em desenvolvimento')">Alterar</a>
                      <a href="#" class="delete-user" data-id="${u.id}" style="color: #fa5252">Remover</a>
                    </div>
                  </div>
                </td>
              </tr>
            `).join('')}
          </tbody>
        </table>
      `;

      // Event listeners para delete (simulativo ou real se tivermos permissão)
      document.querySelectorAll('.delete-user').forEach(btn => {
        btn.addEventListener('click', async (e) => {
          e.preventDefault();
          const id = e.target.dataset.id;
          if (confirm('Deseja realmente remover este usuário do sistema?')) {
             // Nota: No Supabase CLIENT não podemos apagar de AUTH.USERS sem Admin API.
             // Mas podemos apagar do profile para tirar acesso se o RLS permitir.
             const { error } = await supabase.from('user_profiles').delete().eq('id', id);
             if (error) alert(error.message);
             else loadUsers();
          }
        });
      });
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = document.getElementById('email').value;
      const password = document.getElementById('password').value;
      const displayName = document.getElementById('display_name').value;

      statusMsg.style.display = 'block';
      statusMsg.style.background = '#f0f0f0';
      statusMsg.textContent = 'Criando conta...';

      const { error } = await supabase.auth.signUp({
        email,
        password,
        options: { data: { display_name: displayName } }
      });

      if (error) {
        statusMsg.style.background = '#fff0f0';
        statusMsg.style.color = '#e03131';
        statusMsg.textContent = error.message;
      } else {
        statusMsg.style.background = '#f2fcf2';
        statusMsg.style.color = '#0ca678';
        statusMsg.textContent = 'Usuário cadastrado com sucesso! Recarregando...';
        form.reset();
        setTimeout(loadUsers, 1500);
      }
    });

    loadUsers();
  </script>
</AdminLayout>

<style>
  .users-page { padding: 20px 0; }
  .page-header { margin-bottom: 30px; }
  .page-header h1 { font-size: 2rem; margin-bottom: 5px; }
  .page-header p { color: #666; }

  .registration-section { margin-bottom: 30px; }
  .admin-card { background: white; padding: 25px; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.05); }
  .admin-card h3 { margin-bottom: 20px; font-size: 1.1rem; border-bottom: 1px solid #f0f0f0; padding-bottom: 10px; }

  .form-grid { display: grid; grid-template-columns: 1fr 1fr 1fr auto; gap: 15px; align-items: flex-end; }
  .form-group label { display: block; margin-bottom: 8px; font-weight: 600; font-size: 0.85rem; }
  .form-group input { width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 6px; }
  .btn-primary { background: var(--primary); color: white; border: none; padding: 10px 20px; border-radius: 6px; cursor: pointer; font-weight: 600; }

  .admin-table { width: 100%; border-collapse: collapse; margin-top: 10px; }
  .admin-table th { text-align: left; background: #fafafa; padding: 12px; border-bottom: 2px solid #f0f0f0; color: #666; font-size: 0.85rem; text-transform: uppercase; }
  .admin-table td { padding: 15px 12px; border-bottom: 1px solid #f0f0f0; vertical-align: middle; }

  .user-info { display: flex; flex-direction: column; }
  .user-email { font-size: 0.8rem; color: #888; }
  .role-badge { padding: 4px 8px; border-radius: 4px; font-size: 0.75rem; font-weight: 700; background: #e7f5ff; color: #1971c2; }

  /* Dropdown Styles */
  .dropdown { position: relative; display: inline-block; }
  .btn-dots { background: none; border: none; font-size: 1.5rem; cursor: pointer; color: #999; padding: 0 10px; }
  .dropdown-content { display: none; position: absolute; right: 0; background-color: white; min-width: 120px; box-shadow: 0 8px 16px rgba(0,0,0,0.1); z-index: 1; border-radius: 6px; border: 1px solid #eee; }
  .dropdown:hover .dropdown-content { display: block; }
  .dropdown-content a { color: #333; padding: 12px 16px; text-decoration: none; display: block; font-size: 0.9rem; }
  .dropdown-content a:hover { background-color: #f8f9fa; }

  @media (max-width: 900px) {
    .form-grid { grid-template-columns: 1fr; }
  }
</style>
