---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Redefinir Senha - Admin">
  <div class="login-container">
    <h1>Redefinir Senha</h1>
    <p class="description">Digite sua nova senha de acesso.</p>
    
    <form id="reset-form">
      <input 
        type="password" 
        id="password" 
        placeholder="Nova Senha" 
        required 
        minlength="6"
      />
      <input 
        type="password" 
        id="confirm-password" 
        placeholder="Confirme a Nova Senha" 
        required 
      />
      <button type="submit" class="btn-primary">Atualizar Senha</button>
    </form>

    <div id="message" style="display: none; margin-top: 15px; padding: 10px; border-radius: 4px;"></div>
  </div>

  <script>
    import { supabase } from '../../lib/supabase.js';

    const form = document.getElementById('reset-form');
    const msgDiv = document.getElementById('message');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const password = document.getElementById('password').value;
      const confirm = document.getElementById('confirm-password').value;

      if (password !== confirm) {
        msgDiv.style.display = 'block';
        msgDiv.style.background = '#fff0f0';
        msgDiv.style.color = '#e03131';
        msgDiv.textContent = 'As senhas não coincidem!';
        return;
      }
      
      msgDiv.style.display = 'block';
      msgDiv.style.background = '#f0f0f0';
      msgDiv.textContent = 'Atualizando...';

      const { error } = await supabase.auth.updateUser({ password });

      if (error) {
        msgDiv.style.background = '#fff0f0';
        msgDiv.style.color = '#e03131';
        msgDiv.textContent = error.message;
      } else {
        msgDiv.style.background = '#f2fcf2';
        msgDiv.style.color = '#0ca678';
        msgDiv.textContent = 'Senha atualizada com sucesso! Redirecionando...';
        
        setTimeout(() => {
          window.location.href = '/admin/login';
        }, 2000);
      }
    });
  </script>
</BaseLayout>

<style>
  .login-container {
    max-width: 400px;
    margin: 100px auto;
    padding: 40px;
    background: white;
    border-radius: 8px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
  }
  h1 {
    text-align: center;
    margin-bottom: 10px;
    font-size: 1.5rem;
    color: var(--secondary);
  }
  .description {
    text-align: center;
    color: #666;
    margin-bottom: 25px;
    font-size: 0.95rem;
  }
  form {
    display: flex;
    flex-direction: column;
    gap: 15px;
  }
  input {
    padding: 12px;
    border: 1px solid #eee;
    border-radius: 6px;
    outline: none;
  }
</style>
