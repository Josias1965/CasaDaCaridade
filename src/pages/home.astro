---
// src/pages/home.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BlogCard from '../components/BlogCard.astro';
import Sidebar from '../components/Sidebar.astro';
import { supabase } from '../lib/supabase.js';

// Função para converter link do Google Drive em link direto de imagem
function getImageUrl(url: string) {
  if (!url || url === '' || url.includes('exemplo.com')) {
    return 'https://images.unsplash.com/photo-1488521787991-ed7bbaae773c?q=80&w=2070&auto=format&fit=crop';
  }
  const cleanUrl = url.trim();
  if (cleanUrl.includes('drive.google.com')) {
    let id = '';
    if (cleanUrl.includes('/file/d/')) {
      id = cleanUrl.split('/d/')[1]?.split('/')[0];
    } else if (cleanUrl.includes('id=')) {
      id = cleanUrl.split('id=')[1]?.split('&')[0];
    }
    return id ? `https://drive.google.com/thumbnail?id=${id}&sz=w1200` : cleanUrl;
  }
  return cleanUrl;
}

const { data: posts, error } = await supabase
  .from('posts')
  .select(`*, categories (name, slug)`)
  .eq('status', 'published')
  .order('published_at', { ascending: false })
  .limit(4); // Exibir 4 posts conforme solicitado

const authorIds = posts?.map(p => p.author_id) || [];
const { data: authors } = await supabase.from('user_profiles').select('id, display_name').in('id', authorIds);
const authorsMap = Object.fromEntries(authors?.map(a => [a.id, a.display_name]) || []);
---

<BaseLayout title="Casa da Caridade - Blog">
  <Header />
  <main>
    <section class="split-hero">
      <div class="container hero-grid">
        <div class="hero-text">
          <span class="badge">Seja muito bem-vindo</span>
          <h1>Espiritualidade e Fé em <span>cada palavra</span></h1>
          <p>Casa da Caridade: Compartilhando amor, luz e sabedoria para o seu dia a dia.</p>
          <div class="hero-actions">
            <a href="#fluxo" class="btn-primary">Ver Posts Recentes</a>
            <a href="/sobre" class="btn-outline">Conheça Nossa Casa</a>
          </div>
        </div>
        
        <div class="hero-video-wrapper">
          <div class="sequence-container">
            <canvas id="sequence-canvas"></canvas>
            <div class="glass-overlay"></div>
          </div>
        </div>
      </div>
    </section>

    <section id="fluxo" class="posts-section">
      <div class="container layout-grid">
        <div class="main-content">
          <h2 class="section-title">Post Recentes</h2>
          <div class="posts-grid">
            {posts && posts.length > 0 ? (
              posts.map(post => (
                <BlogCard 
                  title={post.title}
                  excerpt={post.excerpt ? (post.excerpt.length > 200 ? post.excerpt.substring(0, 200) + '...' : post.excerpt) : ''}
                  slug={post.slug}
                  image={getImageUrl(post.featured_image)}
                  category={post.categories?.name}
                  author={authorsMap[post.author_id] || 'Administrador'}
                  date={post.published_at}
                />
              ))
            ) : (
              <p>Nenhum post encontrado.</p>
            )}
          </div>
        </div>
        
        <div class="sidebar-wrapper">
          <Sidebar />
        </div>
      </div>

      <div class="container banner-row">
        <a href="/contato" class="horizontal-banner">
          <img src="/images/banner-inferior.png" alt="Participar da Casa da Caridade" onerror="this.style.display='none';" />
          <div class="horizontal-overlay">
            <span>Junte-se a nós nesta caminhada de luz e paz</span>
          </div>
        </a>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<script is:inline>
  // Lógica do Player de Sequência (VÍDEO)
  const canvas = document.getElementById('sequence-canvas');
  if (canvas) {
    const ctx = canvas.getContext('2d');
    const images = [];
    const totalFrames = 60; // Suas 60 imagens
    let currentFrame = 0;

    // Carregar imagens
    for (let i = 0; i < totalFrames; i++) {
        const img = new Image();
        // Formato: Woman_in_prayer_202604111427(1)_000.jpg até 059.jpg
        const frameNumber = i.toString().padStart(3, '0');
        img.src = `/images/hero/Prece/Woman_in_prayer_202604111427(1)_${frameNumber}.jpg`;
        images.push(img);
    }

    function resizeCanvas() {
        const parent = canvas.parentElement;
        canvas.width = parent.clientWidth;
        canvas.height = parent.clientHeight;
    }

    function render() {
        const img = images[currentFrame];
        if (img.complete) {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            
            // Desenhar imagem mantendo o aspecto "cover"
            const scale = Math.max(canvas.width / img.width, canvas.height / img.height);
            const x = (canvas.width / 2) - (img.width / 2) * scale;
            const y = (canvas.height / 2) - (img.height / 2) * scale;
            ctx.drawImage(img, x, y, img.width * scale, img.height * scale);
        }
        
        currentFrame = (currentFrame + 1) % totalFrames;
        setTimeout(() => requestAnimationFrame(render), 60); // Ajuste a velocidade aqui (60ms ~ 16fps)
    }

    window.addEventListener('resize', resizeCanvas);
    resizeCanvas();
    render();
  }
</script>

<style>
  .split-hero {
    background: #fff;
    padding: 80px 0;
    overflow: hidden;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }
  
  .badge {
    background: var(--primary-light, #e0f2f1);
    color: var(--primary);
    padding: 8px 16px;
    border-radius: 50px;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    display: inline-block;
    margin-bottom: 20px;
  }

  .hero-text h1 {
    font-size: 3.5rem;
    line-height: 1.1;
    color: var(--text-dark);
    margin-bottom: 24px;
    font-weight: 800;
  }
  .hero-text h1 span {
    background: linear-gradient(120deg, var(--primary) 0%, var(--secondary) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .hero-text p {
    font-size: 1.2rem;
    color: #555;
    margin-bottom: 40px;
    line-height: 1.6;
  }

  .hero-actions {
    display: flex;
    gap: 15px;
  }
  .btn-primary {
    background: var(--primary);
    color: white;
    padding: 14px 28px;
    border-radius: 8px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
    box-shadow: 0 4px 15px rgba(0, 150, 136, 0.3);
  }
  .btn-outline {
    border: 2px solid #ddd;
    color: var(--text-dark);
    padding: 12px 28px;
    border-radius: 8px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 150, 136, 0.4);
  }

  /* Sequence Video Styling */
  .hero-video-wrapper {
    position: relative;
    width: 100%;
    height: 500px;
  }
  .sequence-container {
    width: 100%;
    height: 100%;
    border-radius: 24px;
    overflow: hidden;
    position: relative;
    box-shadow: 0 20px 50px rgba(0,0,0,0.15);
  }
  #sequence-canvas {
    width: 100%;
    height: 100%;
    display: block;
    background: #000;
  }
  .glass-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.2) 0%, transparent 100%);
    pointer-events: none;
  }

  /* Layout Columns */
  .layout-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 50px;
    padding-bottom: 50px;
  }

  .section-title {
    margin-bottom: 40px;
    font-size: 2.2rem;
    color: var(--text-dark);
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr); /* Forcing 2 columns as requested */
    gap: 30px;
  }

  .banner-row {
    margin-top: 20px;
    padding-bottom: 80px;
  }
  .horizontal-banner {
    display: block;
    position: relative;
    width: 100%;
    height: 550px;
    border-radius: 16px;
    overflow: hidden;
    text-decoration: none;
    background: linear-gradient(135deg, #00796b, #4db6ac);
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .horizontal-banner:hover {
    transform: translateY(-5px);
  }
  .horizontal-banner img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .horizontal-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 60px 40px 30px;
    background: linear-gradient(to top, rgba(0,0,0,0.8), transparent);
    color: white;
    font-size: 1.8rem;
    font-weight: 700;
    text-align: center;
    transition: padding-bottom 0.3s ease;
  }
  .horizontal-banner:hover .horizontal-overlay {
    padding-bottom: 40px;
  }

  @media (max-width: 1024px) {
    .hero-grid { grid-template-columns: 1fr; text-align: center; gap: 40px; }
    .hero-text h1 { font-size: 2.5rem; }
    .hero-text p { margin: 0 auto 30px; }
    .hero-actions { justify-content: center; }
    .hero-video-wrapper { height: 400px; }
    
    .layout-grid { grid-template-columns: 1fr; }
    .sidebar-wrapper { order: 2; }
    .main-content { order: 1; }
    .posts-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 768px) {
    .horizontal-banner {
      height: 350px; 
    }
    .horizontal-banner img {
      object-fit: contain;
      background-color: #0b1120; /* Fundo escuro para a arte não ficar com bordas brancas vazias */
    }
    .horizontal-overlay {
      font-size: 1.1rem;
      padding: 20px 15px;
    }
  }
</style>

</style>
