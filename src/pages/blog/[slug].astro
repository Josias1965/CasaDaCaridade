---
// src/pages/blog/[slug].astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Sidebar from '../../components/Sidebar.astro';
import { supabase } from '../../lib/supabase.js';

const { slug } = Astro.params;

// Função para converter link do Google Drive em link direto de imagem
function getImageUrl(url: string) {
  if (!url || url === '' || url.includes('exemplo.com')) {
    return 'https://images.unsplash.com/photo-1488521787991-ed7bbaae773c?q=80&w=2070&auto=format&fit=crop';
  }
  const cleanUrl = url.trim();
  if (cleanUrl.includes('drive.google.com')) {
    let id = '';
    if (cleanUrl.includes('/file/d/')) {
      id = cleanUrl.split('/d/')[1]?.split('/')[0];
    } else if (cleanUrl.includes('id=')) {
      id = cleanUrl.split('id=')[1]?.split('&')[0];
    }
    return id ? `https://lh3.googleusercontent.com/d/${id}` : cleanUrl;
  }
  return cleanUrl;
}

// Função para converter link do Google Drive em link direto de áudio ou download
function getDownloadUrl(url: string) {
  if (!url) return null;
  const cleanUrl = url.trim();
  if (cleanUrl.includes('drive.google.com')) {
    let id = '';
    if (cleanUrl.includes('/file/d/')) {
      id = cleanUrl.split('/d/')[1]?.split('/')[0];
    } else if (cleanUrl.includes('id=')) {
      id = cleanUrl.split('id=')[1]?.split('&')[0];
    }
    return id ? `https://drive.google.com/uc?id=${id}&export=download` : cleanUrl;
  }
  return cleanUrl;
}

// Função para converter link do Google Drive em link de preview de vídeo ou documento
function getDrivePreviewUrl(url: string) {
  if (!url) return null;
  const cleanUrl = url.trim();
  if (cleanUrl.includes('drive.google.com')) {
    let id = '';
    if (cleanUrl.includes('/file/d/')) {
      id = cleanUrl.split('/d/')[1]?.split('/')[0];
    } else if (cleanUrl.includes('id=')) {
      id = cleanUrl.split('id=')[1]?.split('&')[0];
    }
    return id ? `https://drive.google.com/file/d/${id}/preview` : cleanUrl;
  }
  return cleanUrl;
}

// Buscar o post
const { data: post } = await supabase
  .from('posts')
  .select(`
    *,
    categories (name, slug),
    user_profiles (display_name, avatar_url)
  `)
  .eq('slug', slug)
  .eq('status', 'published')
  .maybeSingle();

if (!post) {
  return Astro.redirect('/404');
}

// Converter a URL do vídeo do YouTube para formato Embed
let embedUrl = null;
if (post.video_url) {
  const url = post.video_url;
  let id = '';
  if (url.includes('v=')) id = url.split('v=')[1]?.split('&')[0];
  else if (url.includes('youtu.be/')) id = url.split('youtu.be/')[1]?.split('?')[0];
  else if (url.includes('youtube.com/embed/')) id = url.split('embed/')[1]?.split('?')[0];
  else id = url.split('/').pop().split('?')[0]; // fallback
  
  if (id) {
    embedUrl = `https://www.youtube.com/embed/${id}`;
  }
}

const audioUrl = getDownloadUrl(post.audio_url);
const driveVideoPreviewUrl = getDrivePreviewUrl(post.drive_video_url);
const driveVideoDownloadUrl = getDownloadUrl(post.drive_video_url);
const slidesPreviewUrl = getDrivePreviewUrl(post.slides_url);
const slidesDownloadUrl = getDownloadUrl(post.slides_url);
---

<BaseLayout title={post.title}>
  <Header />
  <article class="post-page">
    <div class="container layout-grid">
      <div class="main-content">
        <header class="post-header">
          <div class="post-meta">
            <span class="category">{post.categories?.name}</span>
          </div>
          <h1>{post.title}</h1>
        </header>

        <img src={getImageUrl(post.featured_image)} alt={post.title} class="featured-image" />

        {post.excerpt && (
          <div class="post-excerpt">
            <p>{post.excerpt}</p>
          </div>
        )}

        <div class="post-content" set:html={post.content} />

        {audioUrl && (
          <div class="audio-section">
            <h3>Versão em Áudio</h3>
            <div class="audio-player-container">
              {audioUrl.includes('drive.google.com') ? (
                <iframe 
                  src={audioUrl.includes('id=') 
                    ? `https://drive.google.com/file/d/${audioUrl.split('id=')[1].split('&')[0]}/preview`
                    : audioUrl.replace('/view', '') + '/preview'}
                  width="100%" 
                  height="150" 
                  style="border-radius: 12px; border: 1px solid #eee; background: #fafafa;"
                  allow="autoplay"
                ></iframe>
              ) : (
                <audio controls preload="metadata" class="audio-player">
                  <source src={audioUrl} type="audio/mpeg" />
                  Seu navegador não suporta o player de áudio.
                </audio>
              )}
              <div class="audio-fallback">
                <p>Problemas com o player? <a href={audioUrl} target="_blank" rel="noopener noreferrer">Baixar arquivo MP3</a>.</p>
              </div>
            </div>
          </div>
        )}

        {embedUrl && (
          <div class="video-container">
            <iframe 
              src={embedUrl} 
              title="YouTube video player" 
              frameborder="0" 
              allowfullscreen="true"
            ></iframe>
          </div>
        )}

        {driveVideoPreviewUrl && (
          <div class="video-section">
            <div class="video-container">
              <iframe 
                src={driveVideoPreviewUrl} 
                allow="autoplay"
              ></iframe>
            </div>
            {driveVideoDownloadUrl && (
              <div class="video-fallback">
                <p>Problemas com o vídeo? <a href={driveVideoDownloadUrl} target="_blank" rel="noopener noreferrer">Baixar arquivo de vídeo</a>.</p>
              </div>
            )}
          </div>
        )}

        {slidesPreviewUrl && (
          <div class="slides-section">
            <h3>Apresentação em Slide</h3>
            <div class="slides-info">
              {slidesPreviewUrl.includes('drive.google.com') && (
                <div class="slides-preview">
                  <iframe 
                    src={slidesPreviewUrl} 
                    width="100%" 
                    height="450" 
                    style="border-radius: 12px; border: 1px solid #eee; background: #fafafa; margin-bottom: 20px;"
                    allow="autoplay"
                  ></iframe>
                </div>
              )}
              <p>Arquivo: <strong>{post.slides_title || 'Apresentação'}</strong></p>
              <a href={slidesDownloadUrl} target="_blank" rel="noopener noreferrer" class="btn-download-slide">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
                Baixar Apresentação
              </a>
            </div>
          </div>
        )}


        <footer class="post-footer">
          <div class="author-info-footer">
            {post.user_profiles?.avatar_url ? (
              <img src={post.user_profiles.avatar_url} alt={post.user_profiles.display_name} class="avatar" />
            ) : (
              <div class="avatar-placeholder"></div>
            )}
            <div class="author-details">
              <span class="author">Por <strong>{post.user_profiles?.display_name || 'Administrador'}</strong></span>
              <span class="date">{post.published_at ? new Date(post.published_at).toLocaleDateString() : ''}</span>
            </div>
          </div>
        </footer>
      </div>

      <div class="sidebar-wrapper">
        <Sidebar />
      </div>
    </div>
  </article>
  <Footer />
</BaseLayout>

<style>
  .post-page {
    padding: 60px 0;
    background: #f8f9fa;
  }
  
  .layout-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 50px;
  }

  .main-content {
    background: white;
    padding: 40px;
    border-radius: 20px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.03);
  }

  .featured-image {
    width: 100%;
    height: auto;
    max-height: 500px;
    object-fit: cover;
    border-radius: 16px;
    margin-bottom: 40px;
  }
  .post-header {
    margin-bottom: 40px;
  }
  .post-meta {
    font-size: 0.95rem;
    color: #666;
    margin-bottom: 15px;
    display: flex;
    gap: 10px;
    align-items: center;
  }
  .category {
    color: var(--primary);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    font-size: 0.85rem;
  }
  h1 {
    font-size: 3rem;
    margin-bottom: 10px;
    line-height: 1.2;
    color: var(--text-dark);
    font-weight: 800;
  }
  .post-footer {
    margin-top: 50px;
    padding-top: 30px;
    border-top: 1px solid #eee;
  }
  .author-info-footer {
    display: flex;
    align-items: center;
    gap: 15px;
  }
  .author-details {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .author-details .author {
    color: var(--text-dark);
  }
  .author-details .date {
    font-size: 0.9rem;
    color: #666;
  }
  .avatar {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    object-fit: cover;
  }
  .avatar-placeholder {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    background-color: #eee;
  }
  .post-excerpt {
    font-size: 1.25rem;
    line-height: 1.7;
    color: #555;
    font-style: italic;
    border-left: 5px solid var(--primary);
    padding-left: 25px;
    margin-bottom: 40px;
    text-align: justify;
  }
  .post-content {
    font-size: 1.15rem;
    line-height: 1.9;
    color: #333;
    text-align: justify;
  }
  .post-content :global(p) {
    margin-bottom: 1.5rem;
  }
  .post-content :global(h2), .post-content :global(h3) {
    margin: 40px 0 20px;
    color: var(--text-dark);
    font-weight: 700;
  }
  .video-container {
    position: relative;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
    background: #000;
    margin: 40px 0;
    border-radius: 16px;
  }
  .video-container iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  /* Audio & Video Styles */
  .audio-section, .video-section, .slides-section {
    margin: 40px 0;
    padding: 30px;
    background: #fdfdfd;
    border-radius: 16px;
    border: 1px solid #eee;
  }
  .audio-section h3, .slides-section h3 {
    font-size: 1.2rem;
    margin-bottom: 20px;
    color: var(--text-dark);
  }
  .video-fallback, .audio-fallback {
    margin-top: 15px;
    font-size: 0.9rem;
    color: #666;
  }
  .video-fallback a, .audio-fallback a {
    color: var(--primary);
    font-weight: 600;
    text-decoration: none;
  }
  .video-fallback a:hover, .audio-fallback a:hover {
    text-decoration: underline;
  }

  /* Slides Section */
  .slides-info {
    display: flex;
    flex-direction: column;
    gap: 15px;
  }
  .btn-download-slide {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--primary);
    color: white;
    padding: 12px 20px;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    width: fit-content;
    transition: all 0.2s;
  }
  .btn-download-slide:hover {
    background: var(--primary-dark, #000);
    transform: translateY(-2px);
  }
  
  @media (max-width: 1024px) {
    .layout-grid { grid-template-columns: 1fr; }
    .sidebar-wrapper { order: 2; }
    .main-content { order: 1; padding: 25px; }
    h1 { font-size: 2.2rem; }
  }
</style>

